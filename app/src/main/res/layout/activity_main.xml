<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Tab content area — each NavigatorHost occupies this space -->
    <FrameLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_food"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:defaultNavHost="false" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_dashboard"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:defaultNavHost="false" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_me"
            android:name="dev.hotwire.navigation.navigator.NavigatorHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:defaultNavHost="false" />

    </FrameLayout>

    <!-- Bottom navigation bar — hidden until authenticated -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/nav_bar_background"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/tab_icon_tint"
        app:itemTextColor="@color/tab_icon_tint"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
